<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario de Contacto</title>
</head>

<body>
    <h1>Bienvenido al formulario de contacto</h1>

     <form action="/registrar" method="POST">
        <label>Nombre:</label> <br>
        <input type="text" name="fnombre" required>
        <br><br>
        <label>Correo:</label> <br>
        <input type="email" name="fcorreo" required>
        <br><br>
        <label>Edad:</label> <br>
        <input type="number" name="fedad" required>
        <br><br>
        <button type="submit">Guardar contacto e ir al listado</button>
    </form>
    
</body>
</html>